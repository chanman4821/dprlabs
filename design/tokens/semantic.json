{
  "color": {
    "$type": "color",

    "bg":              { "$value": "{palette.warm.900}", "$description": "page canvas / --background" },
    "bg-sunken":       { "$value": "{palette.warm.950}", "$description": "wells / code recesses" },
    "surface":         { "$value": "{palette.warm.850}", "$description": "panels / cards" },
    "surface-raised":  { "$value": "{palette.warm.800}", "$description": "raised / hovered surface" },
    "overlay":         { "$value": "{palette.warm.overlay}", "$description": "modal scrim (dark in both modes)" },

    "border":             { "$value": "{palette.warm.700}", "$description": "dividers / hairlines" },
    "border-strong":      { "$value": "{palette.warm.600}", "$description": "emphasised hairline" },
    "border-interactive": { "$value": "{palette.warm.500}", "$description": "input / control outline (>=3:1)" },

    "text": {
      "primary":        { "$value": "{palette.warm.100}", "$description": "headings + body / --foreground (16.20:1)" },
      "secondary":      { "$value": "{palette.warm.300}", "$description": "sub-copy (10.06:1)" },
      "tertiary":       { "$value": "{palette.warm.400}", "$description": "meta / captions / --muted-foreground (7.18:1)" },
      "on-accent":      { "$value": "{palette.amber.on}",  "$description": "AUTHORITATIVE --primary-foreground: ink ON an amber fill (8.54:1)" },
      "on-accent-cool": { "$value": "{palette.slate.ink}", "$description": "AUTHORITATIVE --accent-foreground: ink ON the slate accent fill (6.37:1)" },
      "on-danger":      { "$value": "{palette.warm.100}",  "$description": "--destructive-foreground: light text ON the danger fill (5.10:1)" }
    },

    "accent":           { "$value": "{palette.amber.500}", "$description": "PRIMARY FILL (amber) — pair with text.on-accent" },
    "accent-hover":     { "$value": "{palette.amber.600}", "$description": "primary FILL hover" },
    "accent-text":      { "$value": "{palette.amber.500}", "$description": "amber as TEXT/ICON/HAIRLINE on page bg (8.82:1)" },
    "accent-secondary": { "$value": "{palette.slate.400}", "$description": "cool slate accent as TEXT/graphic ON the page canvas (dark 7.44:1; flips darker on paper)" },
    "accent-cool":      { "$value": "{palette.slate.400}", "$description": "AUTHORITATIVE --accent: cool slate CHIP/hover FILL (fixed across modes); pair with text.on-accent-cool (6.37:1)" },
    "danger":           { "$value": "{palette.critical.ink}", "$description": "--destructive FILL (dark red); pair with text.on-danger (5.10:1)" },

    "number":     { "$value": "{palette.amber.500}", "$description": "the ONE honest number — amber, body font, tabular" },
    "link":       { "$value": "{palette.amber.400}", "$description": "inline link (12:1)" },
    "link-hover": { "$value": "{palette.amber.500}" },
    "focus":      { "$value": "{palette.amber.400}", "$description": "focus ring (12:1)" },

    "status": {
      "positive":     { "$value": "{palette.positive.text}", "$description": "healthy — TEXT tone (9.9:1)" },
      "positive-ui":  { "$value": "{palette.positive.ui}",   "$description": "healthy — UI/graphic tone (6.5:1)" },
      "critical":     { "$value": "{palette.critical.text}", "$description": "failing — TEXT tone (7.0:1)" },
      "critical-ui":  { "$value": "{palette.critical.ui}",   "$description": "failing — UI/graphic tone (4.2:1)" },
      "attention":    { "$value": "{palette.amber.500}",     "$description": "awaiting decision = the reserved amber" }
    },

    "selection": {
      "bg":   { "$value": "{palette.amber.500}" },
      "text": { "$value": "{palette.warm.900}" }
    }
  }
}
