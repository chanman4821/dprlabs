{
  "$description": "DPR Labs — TIER 1 PRIMITIVE tokens (W3C DTCG). Raw values only, no aliases. Never consumed directly for COLOR (always via a tier-2 semantic role); non-color scales (space, type, radius, motion, z) are used directly by their friendly names. Authoritative brand values come from the design brief and MUST NOT be altered. Neutrals are derived from the brand background hue (30deg) as a warm-gray ramp; every derived neutral is contrast-verified in contrast-audit.mjs.",
  "palette": {
    "$type": "color",
    "warm": {
      "950": { "$value": "#0D0B0A", "$description": "hsl(30 10% 4.5%) — sunken well / deepest recess" },
      "900": { "$value": "#131210", "$description": "hsl(30 9% 7%) — AUTHORITATIVE page canvas (brief bg)" },
      "850": { "$value": "#1A1816", "$description": "hsl(30 9% 9.5%) — surface / panel base" },
      "800": { "$value": "#22201D", "$description": "hsl(30 8% 12.5%) — raised surface" },
      "700": { "$value": "#322E2A", "$description": "hsl(30 8% 18%) — hairline / divider" },
      "600": { "$value": "#47423E", "$description": "hsl(30 7% 26%) — strong hairline" },
      "500": { "$value": "#857C6F", "$description": "hsl(34 9% 48%) — interactive/control border (>=3:1 on canvas)" },
      "400": { "$value": "#A29990", "$description": "hsl(30 9% 60%) — tertiary text (6.7:1 on canvas)" },
      "300": { "$value": "#C5BDB5", "$description": "hsl(30 12% 74%) — secondary text (10.1:1 on canvas)" },
      "100": { "$value": "#F4F0EB", "$description": "hsl(34 28% 94%) — primary text (16.5:1 on canvas)" },
      "overlay": { "$value": "hsl(30 10% 4% / 0.72)", "$description": "modal/scrim backdrop, translucent near-black" }
    },
    "amber": {
      "600": { "$value": "#E6900F", "$description": "hsl(36 88% 48%) — accent hover (darker)" },
      "500": { "$value": "#F6AA28", "$description": "hsl(38 92% 56%) — AUTHORITATIVE brand accent / the-number (brief primary)" },
      "400": { "$value": "#FBC456", "$description": "hsl(40 95% 66%) — focus ring / lighter accent" },
      "ink":  { "$value": "#A46104", "$description": "hsl(35 95% 33%) — dark amber for accent TEXT on light paper (4.6:1)" }
    },
    "orange": {
      "500": { "$value": "#EE851B", "$description": "hsl(30 86% 52%) — AUTHORITATIVE secondary accent (brief accent-2)" }
    },
    "positive": {
      "text": { "$value": "#6CD09E", "$description": "hsl(150 52% 62%) — healthy status TEXT on dark (9.9:1)" },
      "ui":   { "$value": "#3FAB75", "$description": "hsl(150 46% 46%) — healthy status UI/graphic on dark (6.5:1)" },
      "ink":  { "$value": "#1E7147", "$description": "hsl(150 58% 28%) — healthy status TEXT on light (5.7:1)" }
    },
    "critical": {
      "text": { "$value": "#F07C6A", "$description": "hsl(8 82% 68%) — failing status TEXT on dark (7.0:1)" },
      "ui":   { "$value": "#D84231", "$description": "hsl(6 68% 52%) — failing status UI/graphic on dark (4.2:1)" },
      "ink":  { "$value": "#BA261C", "$description": "hsl(4 74% 42%) — failing status TEXT on light (5.9:1)" }
    },
    "paper": {
      "surface":         { "$value": "#FDFDFB", "$description": "hsl(40 40% 99%) — light raised surface" },
      "canvas":          { "$value": "#FAF8F5", "$description": "hsl(38 33% 97%) — light reading-mode canvas (warm paper)" },
      "sunken":          { "$value": "#F3F0EC", "$description": "hsl(36 24% 94%) — light sunken well" },
      "hairline":        { "$value": "#E4DFD7", "$description": "hsl(34 20% 87%) — light divider" },
      "hairline-strong": { "$value": "#D0C7BE", "$description": "hsl(32 16% 78%) — light strong hairline" },
      "border":          { "$value": "#7E7467", "$description": "hsl(32 10% 45%) — light interactive/control border" },
      "text-tertiary":   { "$value": "#756B61", "$description": "hsl(30 9% 42%) — light tertiary text (4.9:1 on paper)" },
      "text-secondary":  { "$value": "#5F574E", "$description": "hsl(30 10% 34%) — light secondary text (6.7:1 on paper)" },
      "text-primary":    { "$value": "#26211D", "$description": "hsl(28 14% 13%) — light primary text (15:1 on paper)" }
    }
  },

  "font": {
    "display": { "$type": "fontFamily", "$value": "'Space Grotesk', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Arial, sans-serif", "$description": "Display / headings / eyebrows. ONE display family." },
    "body":    { "$type": "fontFamily", "$value": "'IBM Plex Sans', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Arial, sans-serif", "$description": "Body / UI / ALL figures (prices, %, counters)." },
    "mono":    { "$type": "fontFamily", "$value": "'IBM Plex Mono', ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, 'Liberation Mono', monospace", "$description": "Code / config / IDs ONLY. Never prices, labels, headings." },
    "numeric": { "$type": "other", "$value": "tabular-nums", "$description": "font-variant-numeric applied globally so every figure aligns." }
  },

  "fw": {
    "$type": "fontWeight",
    "regular":  { "$value": 400 },
    "medium":   { "$value": 500 },
    "semibold": { "$value": 600 },
    "bold":     { "$value": 700 }
  },

  "fs": {
    "$type": "dimension",
    "caption": { "$value": "0.8125rem", "$description": "13px — caption / meta (fixed)" },
    "small":   { "$value": "0.875rem",  "$description": "14px — small UI / footnote (fixed)" },
    "body":    { "$value": "1rem",       "$description": "16px — body base" },
    "lead":    { "$value": "clamp(1.0625rem, 1.01rem + 0.28vw, 1.1875rem)", "$description": "17->19px — lead paragraph" },
    "h5":      { "$value": "clamp(1.1875rem, 1.09rem + 0.48vw, 1.4375rem)", "$description": "19->23px" },
    "h4":      { "$value": "clamp(1.4375rem, 1.28rem + 0.79vw, 1.875rem)",  "$description": "23->30px" },
    "h3":      { "$value": "clamp(1.75rem, 1.5rem + 1.25vw, 2.4375rem)",    "$description": "28->39px" },
    "h2":      { "$value": "clamp(2.1875rem, 1.79rem + 1.98vw, 3.25rem)",   "$description": "35->52px" },
    "h1":      { "$value": "clamp(2.75rem, 2.1rem + 3.25vw, 4.5rem)",       "$description": "44->72px" },
    "display": { "$value": "clamp(3.5rem, 2.3rem + 6vw, 6.75rem)",          "$description": "56->108px — hero display" }
  },

  "lh": {
    "$type": "number",
    "tight":   { "$value": 1.05, "$description": "display / hero" },
    "heading": { "$value": 1.14, "$description": "h1-h3" },
    "snug":    { "$value": 1.3,  "$description": "h4-h5 / lead" },
    "lead":    { "$value": 1.5,  "$description": "large intro copy" },
    "body":    { "$value": 1.6,  "$description": "body paragraphs" },
    "mono":    { "$value": 1.55, "$description": "code blocks" }
  },

  "ls": {
    "display": { "$type": "dimension", "$value": "-0.02em",  "$description": "display: optically tightened" },
    "heading": { "$type": "dimension", "$value": "-0.012em", "$description": "headings" },
    "body":    { "$type": "dimension", "$value": "0em",      "$description": "body default" },
    "label":   { "$type": "dimension", "$value": "0.08em",   "$description": "eyebrows / micro-labels" },
    "mono":    { "$type": "dimension", "$value": "0em",      "$description": "code" }
  },

  "space": {
    "$type": "dimension",
    "0":    { "$value": "0" },
    "hair": { "$value": "1px",   "$description": "hairline detail only" },
    "2xs":  { "$value": "2px" },
    "1":    { "$value": "4px" },
    "2":    { "$value": "8px",   "$description": "8px base unit" },
    "3":    { "$value": "12px" },
    "4":    { "$value": "16px" },
    "5":    { "$value": "24px" },
    "6":    { "$value": "32px" },
    "7":    { "$value": "40px" },
    "8":    { "$value": "48px" },
    "9":    { "$value": "64px" },
    "10":   { "$value": "80px" },
    "11":   { "$value": "96px" },
    "12":   { "$value": "128px" },
    "13":   { "$value": "160px" }
  },

  "radius": {
    "$type": "dimension",
    "none": { "$value": "0" },
    "sm":   { "$value": "4px" },
    "md":   { "$value": "8px" },
    "lg":   { "$value": "12px" },
    "xl":   { "$value": "16px" },
    "pill": { "$value": "999px" }
  },

  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px hsl(30 12% 3% / 0.40)", "$description": "subtle lift; depth from value+light, not stacks" },
    "md": { "$value": "0 6px 20px -8px hsl(30 12% 3% / 0.55)", "$description": "menus / popovers" },
    "lg": { "$value": "0 20px 48px -16px hsl(30 12% 3% / 0.60)", "$description": "modal / overlay only" }
  },

  "dur": {
    "$type": "duration",
    "instant":   { "$value": "80ms" },
    "fast":      { "$value": "160ms" },
    "base":      { "$value": "280ms" },
    "slow":      { "$value": "480ms" },
    "cinematic": { "$value": "800ms" }
  },

  "ease": {
    "$type": "cubicBezier",
    "standard": { "$value": "cubic-bezier(0.2, 0, 0, 1)",    "$description": "default ease-out; no overshoot" },
    "entrance": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$description": "strong ease-out for reveals; no bounce" },
    "exit":     { "$value": "cubic-bezier(0.4, 0, 1, 1)",    "$description": "accelerate out" },
    "linear":   { "$value": "linear",                        "$description": "progress / marquee only" }
  },

  "z": {
    "$type": "number",
    "below":   { "$value": -1 },
    "base":    { "$value": 0 },
    "raised":  { "$value": 10 },
    "sticky":  { "$value": 50 },
    "overlay": { "$value": 90 },
    "nav":     { "$value": 100 },
    "modal":   { "$value": 200 },
    "toast":   { "$value": 300 }
  },

  "layout": {
    "$type": "dimension",
    "maxw":        { "$value": "1240px", "$description": "content column max" },
    "reading-max": { "$value": "680px",  "$description": "blog / prose measure" },
    "nav-height":  { "$value": "72px",   "$description": "fixed top nav height" },
    "gutter":      { "$value": "clamp(1.25rem, 4vw, 4.5rem)", "$description": "page gutter" },
    "rail":        { "$value": "62%",    "$description": "editorial asymmetry: rich-media share of the split" }
  }
}
