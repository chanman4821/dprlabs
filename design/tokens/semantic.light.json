{
  "$description": "DPR Labs — TIER 2 SEMANTIC color roles (LIGHT / reading mode). Same paths as semantic.json so EVERY adaptable role has a value in BOTH declared modes (no wrong-fallback gaps). Emitted under [data-theme='light']. Amber GRAPHIC/TEXT roles flip to the darker amber.ink so they stay >=4.5:1 on warm paper; FILL roles keep the bright amber with dark on-accent text.",
  "color": {
    "$type": "color",

    "bg":              { "$value": "{palette.paper.canvas}" },
    "bg-sunken":       { "$value": "{palette.paper.sunken}" },
    "surface":         { "$value": "{palette.paper.surface}" },
    "surface-raised":  { "$value": "{palette.paper.surface}" },
    "overlay":         { "$value": "{palette.warm.overlay}" },

    "border":             { "$value": "{palette.paper.hairline}" },
    "border-strong":      { "$value": "{palette.paper.hairline-strong}" },
    "border-interactive": { "$value": "{palette.paper.border}" },

    "text": {
      "primary":   { "$value": "{palette.paper.text-primary}" },
      "secondary": { "$value": "{palette.paper.text-secondary}" },
      "tertiary":  { "$value": "{palette.paper.text-tertiary}" },
      "on-accent": { "$value": "{palette.warm.900}" }
    },

    "accent":           { "$value": "{palette.amber.500}", "$description": "FILL stays bright; dark text sits on it" },
    "accent-hover":     { "$value": "{palette.amber.600}" },
    "accent-text":      { "$value": "{palette.amber.ink}", "$description": "amber as TEXT on paper (4.6:1)" },
    "accent-secondary": { "$value": "{palette.amber.ink}", "$description": "orange is too light on paper — use dark amber" },

    "number":     { "$value": "{palette.amber.ink}" },
    "link":       { "$value": "{palette.amber.ink}" },
    "link-hover": { "$value": "{palette.amber.ink}" },
    "focus":      { "$value": "{palette.amber.ink}", "$description": "focus ring on paper (4.6:1)" },

    "status": {
      "positive":     { "$value": "{palette.positive.ink}", "$description": "5.7:1 on paper" },
      "positive-ui":  { "$value": "{palette.positive.ink}" },
      "critical":     { "$value": "{palette.critical.ink}", "$description": "5.9:1 on paper" },
      "critical-ui":  { "$value": "{palette.critical.ink}" },
      "attention":    { "$value": "{palette.amber.ink}" }
    },

    "selection": {
      "bg":   { "$value": "{palette.amber.500}" },
      "text": { "$value": "{palette.warm.900}" }
    }
  }
}
